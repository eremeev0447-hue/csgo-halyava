<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Вход в админку</title>
  <style>
    body { background: #0f0f0f; color: white; font-family: Arial; text-align: center; padding: 100px 20px; }
    input { padding: 15px; font-size: 18px; width: 300px; margin: 10px; background: #1a1a1a; border: 1px solid #333; color: white; border-radius: 8px; }
    button { padding: 15px 30px; font-size: 18px; background: #ffd700; color: black; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; }
    button:hover { background: #e6c200; }
    .error { color: #ff4444; margin-top: 15px; font-size: 16px; }
  </style>
</head>
<body>
  <h1>Вход в админ-панель</h1>
  <form method="POST" action="/admin/login">
    <input type="password" name="password" placeholder="Введите пароль" required autocomplete="current-password"><br>
    <button type="submit">Войти</button>
  </form>
  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>
</body>
</html>
