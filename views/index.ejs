<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CS:GO Халява</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

  <!-- ШАПКА -->
  <div class="site-header">
    <img src="/images/banner.png" alt="ХАЛЯВА FASTERA">
  </div>

  <!-- ОСНОВНОЙ КОНТЕНТ -->
  <div class="site-body">

    <nav class="tabs">
      <button class="tab-button active" onclick="showTab(0)">ХАЛЯВА</button>
      <button class="tab-button" onclick="showTab(1)">РОЗЫГРЫШИ</button>
      <button class="tab-button" onclick="showTab(2)">FAQ</button>
    </nav>

    <div id="tab-0" class="tab-content active">
      <div class="grid">
        <% cards.forEach(card => { %>
        <div class="card" onclick="openCard('<%= card._id %>')">

          <!-- ВЕРХ: текст + бейджи -->
          <div class="card-top">
            <p class="card-title"><%= card.description %></p>
            <% if (card.subtext) { %><p class="small card-subtext"><%= card.subtext %></p><% } %>
            <div class="badges">
              <% (card.badges || []).forEach(b => { %><span class="badge <%= b.toLowerCase() %>"><%= b %></span><% }); %>
            </div>
          </div>

          <!-- КАРТИНКА -->
          <img src="<%= card.image %>" class="logo" alt="<%= card.title %>">

          <!-- НИЗ: промокод + кнопка -->
          <div class="card-bottom">
            <% if (card.promoCode) { %>
            <div class="promo-btn" onclick="event.stopImmediatePropagation(); copyPromoMain('<%= card.promoCode.replace(/'/g, "\\'") %>', this)">
              🎁 Скопировать промокод 🎁
            </div>
            <% } %>
            <a href="<%= card.link %>" target="_blank" class="btn" onclick="event.stopImmediatePropagation()">ПОЛУЧИТЬ ХАЛЯВУ</a>
          </div>
        </div>
        <% }); %>
      </div>
      <% if (cards.length === 0) { %>
        <p style="text-align:center; color:#666; margin-top:80px; font-size:1.2rem;">Карточек пока нет</p>
      <% } %>
    </div>

    <div id="tab-1" class="tab-content">
      <h2 style="text-align:center; margin-top:100px; color:#666;">Розыгрыши</h2>
      <p style="text-align:center; color:#888;">Скоро здесь будут розыгрыши</p>
    </div>

    <div id="tab-2" class="tab-content">
      <% if (faq.length === 0) { %>
        <p style="text-align:center; color:#666; margin-top:80px; font-size:1.2rem;">Вопросов пока нет</p>
      <% } else { %>
        <div class="faq-container">
          <% faq.forEach((item, i) => { %>
          <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(<%= i %>)">
              <span><%= item.question %></span>
              <span class="faq-arrow" id="arrow-<%= i %>">▼</span>
            </button>
            <div class="faq-answer" id="faq-answer-<%= i %>">
              <%= item.answer %>
            </div>
          </div>
          <% }); %>
        </div>
      <% } %>
    </div>

  </div>

  <!-- ФУТЕР -->
